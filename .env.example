# AgentKit — Variables de entorno
# Copia este archivo como .env y llena tus datos:
#   cp .env.example .env
#
# Claude Code te ayuda a llenar estos valores durante el setup.
# NUNCA subas el archivo .env a GitHub.

# ── Anthropic API ──────────────────────────────────────────
# Obtener en: https://platform.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── Proveedor de WhatsApp ──────────────────────────────────
# Opciones: meta | twilio
WHATSAPP_PROVIDER=

# ── Meta Cloud API (si WHATSAPP_PROVIDER=meta) ────────────
# Configurar en: https://developers.facebook.com
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=jumping-fit-verify-2026
META_APP_SECRET=
META_WABA_ID=
# META_API_VERSION=v21.0

# ── Twilio (si WHATSAPP_PROVIDER=twilio) ──────────────────
# Configurar en: https://twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Servidor ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# URL pública de la web (para links en WhatsApp)
WEB_PUBLIC_URL=https://TU-DOMINIO.com/web/

# IA
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
AI_MAX_TOKENS=256

# ── Base de datos ─────────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Produccion (PostgreSQL / Supabase pooler transaction mode, puerto 6543):
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[pass]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ── Admin panel web ───────────────────────────────────────
SECRET_KEY=genera-un-string-largo-aleatorio
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esto

# ── Admin Jump Zone (opcional, también en config/business.yaml) ──
# ADMIN_PHONES=+573013892917
